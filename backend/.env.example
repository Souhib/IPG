# IBG Environment Configuration
# Copy this file to .env and .env.development (or .env.production)

# Environment selector (put in .env)
IBG_ENV=development

# Database (use sqlite+aiosqlite for dev, postgresql+asyncpg for prod)
DATABASE_URL=sqlite+aiosqlite:///database.db

# Redis
REDIS_OM_URL=redis://localhost:6379

# Environment
ENVIRONMENT=development

# Logging
LOG_LEVEL=DEBUG

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-here
JWT_ENCRYPTION_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
FRONTEND_URL=http://localhost:3000

# CORS (comma-separated or JSON array)
CORS_ORIGINS=*

# Logfire (optional)
LOGFIRE_TOKEN=
